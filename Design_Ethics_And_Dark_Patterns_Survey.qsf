e}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID36", "SecondaryAttribute": "How mentally demanding was it to make decisions using this interface?(NASA-TLX Adaptation)", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How mentally demanding was it to make decisions using this interface?<br><em>(NASA-TLX Adaptation)</em></span></span>", "DefaultChoices": false, "DataExportTag": "Q36", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How mentally demanding was it to make decisions using this interface?(NASA-TLX Adaptation)", "Choices": {"1": {"Display": "1 - Not demanding at all"}, "2": {"Display": "2"}, "3": {"Display": "3"}, "4": {"Display": "4"}, "5": {"Display": "5"}, "6": {"Display": "6"}, "7": {"Display": "7 - Extremely demanding"}}, "ChoiceOrder": ["1", "2", "3", "4", "5", "6", "7"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 8, "NextAnswerId": 1, "QuestionID": "QID36", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID37", "SecondaryAttribute": "How much effort did you put into understanding the options presented?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How much effort did you put into understanding the options presented?</span></span>", "DefaultChoices": false, "DataExportTag": "Q37", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How much effort did you put into understanding the options presented?", "Choices": {"1": {"Display": "1 - Very little effort"}, "2": {"Display": "2"}, "3": {"Display": "3"}, "4": {"Display": "4"}, "5": {"Display": "5"}, "6": {"Display": "6"}, "7": {"Display": "7 - Very much effort"}}, "ChoiceOrder": ["1", "2", "3", "4", "5", "6", "7"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 8, "NextAnswerId": 1, "QuestionID": "QID37", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID38", "SecondaryAttribute": "Please briefly describe how you decided what options to select:", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">Please briefly describe how you decided what options to select:</span></span>", "DefaultChoices": false, "DataExportTag": "Q38", "QuestionType": "TE", "Selector": "ML", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Please briefly describe how you decided what options to select:", "Validation": {"Settings": {"ForceResponse": "OFF", "ForceResponseType": "OFF", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1, "QuestionID": "QID38", "DataVisibility": {"Private": false, "Hidden": false}, "SearchSource": {"AllowFreeResponse": "false"}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID39", "SecondaryAttribute": "Was there anything about this interface that you found confusing or frustrating?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">Was there anything about this interface that you found confusing or frustrating?</span></span>", "DefaultChoices": false, "DataExportTag": "Q39", "QuestionType": "TE", "Selector": "ML", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Was there anything about this interface that you found confusing or frustrating?", "Validation": {"Settings": {"ForceResponse": "OFF", "ForceResponseType": "OFF", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1, "QuestionID": "QID39", "DataVisibility": {"Private": false, "Hidden": false}, "SearchSource": {"AllowFreeResponse": "false"}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID4", "SecondaryAttribute": "What is your highest level of education completed?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">What is your highest level of education completed?</span></span>", "DefaultChoices": false, "DataExportTag": "Q4", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "What is your highest level of education completed?", "Choices": {"1": {"Display": "High school"}, "2": {"Display": "Bachelor's degree"}, "3": {"Display": "Master's degree"}, "4": {"Display": "Doctorate"}, "5": {"Display": "Other"}}, "ChoiceOrder": ["1", "2", "3", "4", "5"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 6, "NextAnswerId": 1, "QuestionID": "QID4", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID40", "SecondaryAttribute": "Debriefing Statement — Understanding Dark Patterns in Digital Interfaces\n\n\nThank you for participa", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:19px;\"><strong>Debriefing Statement — Understanding Dark Patterns in Digital Interfaces</strong></span>\n\n<p><br>\nThank you for participating in this study! Now that you have completed all tasks, we want to provide you with complete information about the purpose and methods of this research.<br>\n<br>\n<strong>What This Study Was Really About:</strong><br>\nThis study investigated how different interface designs affect user’s security and privacy decision-making. Specifically, we examined the impact of “dark patterns” — design techniques that may manipulate users into making choices that may not be in their best interest.<br>\n<br>\n<strong>Why We Used Deception:</strong><br>\nWe did not initially disclose that some interfaces were specifically designed to be manipulative. This temporary deception was necessary because knowing in advance would have changed how you interacted with them.<br>\n<br>\n<strong>Types of Dark Patterns Studied:</strong><br>\n• <strong>Obstruction:</strong> Making privacy-protective choices difficult through extra steps or hidden options.<br>\n• <strong>Sneaking:</strong> Hiding information, using pre-checked boxes, or adding features without clear consent.<br>\n• <strong>Interface Interference:</strong> Visual manipulation to guide users toward less secure choices through color, size, and positioning.<br>\n<br>\n<strong>Important:</strong> If you found yourself making choices you wouldn’t normally make, please know this is the intended effect of dark patterns — not a reflection of your abilities. These techniques are designed to exploit normal cognitive processes and affect most users, including experts.<br>\n<br>\n<strong>How to Protect Yourself:</strong><br>\n• Slow down when making privacy decisions, especially if you feel rushed.<br>\n• Look for the least prominent option — it’s often more privacy-protective.<br>\n• Check for pre-selected boxes and uncheck anything you don’t want.<br>\n• Be suspicious of emotional language designed to make you feel guilty.<br>\n• Use browser extensions that help identify dark patterns.<br>\n<br>\n<strong>Your Data and Withdrawal Rights:</strong><br>\nAll interfaces were simulations — no real data was collected or shared. If you wish to withdraw your data, contact the researcher within 14 days using your participant ID.<br>\n<br>\nContact: Neha Kotwal (nehajk@uw.edu) | Kshitij Barapatre (kshitij2@uw.edu)</p>", "DefaultChoices": false, "DataExportTag": "Q40", "QuestionID": "QID40", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Debriefing Statement — Understanding Dark Patterns in Digital Interfaces\n\n\nThank you for participati", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID41", "SecondaryAttribute": "After learning about the true nature of this study, do you wish to withdraw your data?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">After learning about the true nature of this study, do you wish to withdraw your data?</span></span>", "DefaultChoices": false, "DataExportTag": "Q41", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "After learning about the true nature of this study, do you wish to withdraw your data?", "Choices": {"1": {"Display": "No, I consent to my data being used in this research"}, "2": {"Display": "Yes, I wish to withdraw my data"}}, "ChoiceOrder": ["1", "2"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 3, "NextAnswerId": 1, "QuestionID": "QID41", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID42", "SecondaryAttribute": "How did the effort/time required to complete this survey compare to your expectations?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How did the effort/time required to complete this survey compare to your expectations?</span></span>", "DefaultChoices": false, "DataExportTag": "Q42", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How did the effort/time required to complete this survey compare to your expectations?", "Choices": {"1": {"Display": "Easier than expected"}, "2": {"Display": "About what I expected"}, "3": {"Display": "More effort than expected"}}, "ChoiceOrder": ["1", "2", "3"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 4, "NextAnswerId": 1, "QuestionID": "QID42", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID5", "SecondaryAttribute": "How many hours per day do you typically spend using digital devices?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How many hours per day do you typically spend using digital devices?</span></span>", "DefaultChoices": false, "DataExportTag": "Q5", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How many hours per day do you typically spend using digital devices?", "Choices": {"1": {"Display": "Less than 1"}, "2": {"Display": "1-3"}, "3": {"Display": "4-6"}, "4": {"Display": "7-9"}, "5": {"Display": "10+"}}, "ChoiceOrder": ["1", "2", "3", "4", "5"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 6, "NextAnswerId": 1, "QuestionID": "QID5", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID6", "SecondaryAttribute": "How would you rate your overall technical expertise?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How would you rate your overall technical expertise?</span></span>", "DefaultChoices": false, "DataExportTag": "Q6", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How would you rate your overall technical expertise?", "Choices": {"1": {"Display": "Basic"}, "2": {"Display": "Intermediate"}, "3": {"Display": "Advanced"}, "4": {"Display": "Expert"}}, "ChoiceOrder": ["1", "2", "3", "4"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 5, "NextAnswerId": 1, "QuestionID": "QID6", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID7", "SecondaryAttribute": "How often do you review privacy settings when installing a new app?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How often do you review privacy settings when installing a new app?</span></span>", "DefaultChoices": false, "DataExportTag": "Q7", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How often do you review privacy settings when installing a new app?", "Choices": {"1": {"Display": "Never"}, "2": {"Display": "Rarely"}, "3": {"Display": "Sometimes"}, "4": {"Display": "Often"}, "5": {"Display": "Always"}}, "ChoiceOrder": ["1", "2", "3", "4", "5"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 6, "NextAnswerId": 1, "QuestionID": "QID7", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID8", "SecondaryAttribute": "How often do you read cookie consent notices on websites?", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">How often do you read cookie consent notices on websites?</span></span>", "DefaultChoices": false, "DataExportTag": "Q8", "QuestionType": "MC", "Selector": "SAVR", "SubSelector": "TX", "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "How often do you read cookie consent notices on websites?", "Choices": {"1": {"Display": "Never"}, "2": {"Display": "Rarely"}, "3": {"Display": "Sometimes"}, "4": {"Display": "Often"}, "5": {"Display": "Always"}}, "ChoiceOrder": ["1", "2", "3", "4", "5"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 6, "NextAnswerId": 1, "QuestionID": "QID8", "DataVisibility": {"Private": false, "Hidden": false}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID9", "SecondaryAttribute": "Please indicate your level of agreement with each statement.(IUIPC-8 Scale; Malhotra, Kim, &amp; Aga", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:16px;\"><span style=\"font-family:arial,helvetica,sans-serif;\">Please indicate your level of agreement with each statement.<br><br><em>(IUIPC-8 Scale; Malhotra, Kim, &amp; Agarwal, 2004)</em></span></span>", "DefaultChoices": false, "DataExportTag": "Q9", "QuestionType": "Matrix", "Selector": "Likert", "SubSelector": "SingleAnswer", "Configuration": {"QuestionDescriptionOption": "UseText", "TextPosition": "inline", "ChoiceColumnWidth": 25, "RepeatHeaders": "none", "WhiteSpace": "OFF", "MobileFirst": true}, "QuestionDescription": "Please indicate your level of agreement with each statement.(IUIPC-8 Scale; Malhotra, Kim, &amp; Aga", "Choices": {"1": {"Display": "Consumer online privacy is really a matter of consumers' right to exercise control over how their personal information is collected, used and shared."}, "2": {"Display": "Consumer control of personal information lies at the heart of consumer privacy."}, "3": {"Display": "Companies seeking information online should disclose the way the data are collected, processed, and used."}, "4": {"Display": "A good consumer online privacy policy should have a clear and conspicuous disclosure."}, "5": {"Display": "It usually bothers me when online companies ask me for personal information."}, "6": {"Display": "When online companies ask me for personal information, I sometimes think twice before providing it."}, "7": {"Display": "It bothers me to give personal information to so many online companies."}, "8": {"Display": "I'm concerned that online companies are collecting too much personal information about me."}}, "ChoiceOrder": ["1", "2", "3", "4", "5", "6", "7", "8"], "Validation": {"Settings": {"ForceResponse": "RequestResponse", "ForceResponseType": "RequestResponse", "Type": "None"}}, "GradingData": [{"AnswerID": 1, "ChoiceID": "137", "Grades": {"SC_8c7VR8aUqjvSLeR": 1}, "index": 0}, {"AnswerID": 2, "ChoiceID": "137", "Grades": {"SC_8c7VR8aUqjvSLeR": 2}, "index": 1}, {"AnswerID": 3, "ChoiceID": "137", "Grades": {"SC_8c7VR8aUqjvSLeR": 3}, "index": 2}, {"AnswerID": 4, "ChoiceID": "137", "Grades": {"SC_8c7VR8aUqjvSLeR": 4}, "index": 3}, {"AnswerID": 5, "ChoiceID": "137", "Grades": {"SC_8c7VR8aUqjvSLeR": 5}, "index": 4
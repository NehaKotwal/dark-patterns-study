, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SO", "PrimaryAttribute": "Survey Options", "SecondaryAttribute": null, "TertiaryAttribute": null, "Payload": {"BackButton": "false", "SaveAndContinue": "true", "SurveyProtection": "PublicSurvey", "BallotBoxStuffingPrevention": "true", "NoIndex": "Yes", "SecureResponseFiles": "true", "SurveyExpiration": null, "SurveyTermination": "DefaultMessage", "Header": "", "Footer": "", "ProgressBarDisplay": "NoText", "PartialData": "+1 week", "ValidationMessage": null, "PreviousButton": " ← ", "NextButton": " → ", "SkinLibrary": "Qualtrics", "SkinType": "MQ", "Skin": "v4qualtrics1", "NewScoring": 1, "libraryId": "", "nextButtonMid": "", "previousButtonMid": "", "headerMid": "", "footerMid": "", "QuestionsPerPage": "", "PageTransition": "Slide", "Autofocus": "false", "Autoadvance": "false", "AutoadvancePages": "false", "ExternalCSS": null, "HighlightQuestions": "off", "EOSMessage": "", "ShowExportTags": "false", "CollectGeoLocation": "false", "SurveyTitle": "Online Survey Software | Qualtrics Survey Solutions", "SurveyMetaDescription": "Qualtrics sophisticated online survey software solutions make creating online surveys easy. Learn more about Research Suite and get a free account today.", "PasswordProtection": "No", "AnonymizeResponse": "No", "Password": "", "RefererCheck": "No", "RefererURL": "http://", "RecaptchaV3": "false", "ResponseSummary": "No", "EOSMessageLibrary": "", "EOSRedirectURL": "https://", "EmailThankYou": "false", "ThankYouEmailMessageLibrary": null, "ThankYouEmailMessage": null, "ValidateMessage": "false", "ValidationMessageLibrary": null, "InactiveSurvey": "DefaultMessage", "PartialDataCloseAfter": "LastActivity", "ActiveResponseSet": null, "InactiveMessageLibrary": "", "InactiveMessage": "", "AvailableLanguages": {"EN": []}}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID1", "SecondaryAttribute": "Design Ethics and User Interface Study - Informed Consent\n\n\nYou are invited to participate in a rese", "TertiaryAttribute": null, "Payload": {"QuestionText": "<span style=\"font-size:19px;\"><strong>Design Ethics and User Interface Study - Informed Consent</strong></span>\n\n<p><br>\nYou are invited to participate in a research study examining how different interface designs affect user decision-making in privacy and security contexts. This study aims to understand how users interact with various types of digital interfaces when making choices about their personal information and security settings.<br>\n<br>\n<strong>Study Procedures:</strong><br>\nIf you agree to participate, you will:<br>\n1. Complete a brief demographic and technology use questionnaire (approximately 5 minutes).<br>\n2. View a series of mock digital interfaces and make decisions about privacy/security settings (approximately 15-20 minutes).<br>\n3. Answer questions about your experience and decision-making process (approximately 10 minutes).<br>\n<br>\nTotal estimated time: approximately 30 minutes.<br>\n<br>\n<strong>Risks and Discomforts:</strong><br>\nThis study involves minimal risk. You will interact with simulated interfaces that do not access any of your real personal data or accounts. Some interfaces may be designed to be confusing or misleading as part of the research design. No real consequences will result from any choices you make. Full explanation will be provided during debriefing.<br>\n<br>\n<strong>Benefits:</strong><br>\nThis research will contribute to understanding how interface design affects user security decisions. After completing the study, you will receive educational information about identifying potentially manipulative design patterns.<br>\n<br>\n<strong>Confidentiality:</strong><br>\nYou will be assigned a random participant ID. All data will be stored on encrypted, password-protected devices. Results will be reported in aggregate form. Data will be retained for 3 years after study completion and then securely deleted.<br>\n<br>\n<strong>Voluntary Participation:</strong><br>\nYour participation is entirely voluntary. You may withdraw at any time without penalty. You may request data removal up to 14 days after participation.<br>\n<br>\n<strong>Compensation:</strong><br>\nParticipants will receive $20 USD for completing the study (approximately 30 minutes). Participants recruited through university participant pools may alternatively receive course credit as specified by their instructor.<br>\n<br>\n<strong>Investigators:</strong> Neha Kotwal (nehajk@uw.edu) and Kshitij Barapatre (kshitij2@uw.edu)<br>\n<strong>Faculty Advisor:</strong> Marc Dupuis (marcjd@uw.edu)<br>\n<br>\n<strong>YOU MUST BE 18 YEARS OF AGE OR OLDER TO PARTICIPATE.</strong><br><br>\n</p>\n\n<strong>CONSENT TO STUDY PARTICIPATION</strong><br><br>\nI certify that I am 18 years of age or older, that I have read the preceding, and that I understand its contents. By clicking on the next button, I am freely agreeing to participate in this study.<br><br>\n<em>NOTE: If you do not wish to participate in this study then please close your browser window at this time.</em>", "DefaultChoices": false, "DataExportTag": "Q1", "QuestionID": "QID1", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Design Ethics and User Interface Study - Informed Consent\n\n\nYou are invited to participate in a rese", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID10", "SecondaryAttribute": "Scenario: App Permission Request", "TertiaryAttribute": null, "Payload": {"QuestionText": "<strong>Scenario: App Permission Request</strong><br><br>A fictional social media app requests various permissions during installation. Review the permission requests and decide which permissions to grant or deny.<br><br>Permissions: Camera access, Location (always), Contacts, Microphone, Photo library<br><br><em>Please interact with the interface as you normally would.</em><br><br><br><a href=\"https://nehakotwal.github.io/dark-patterns-study/s1_control_app_permissions.html\" target=\"_blank\"><strong>&gt;&gt;&gt; CLICK HERE TO OPEN THE CONNECT HUB INTERFACE &lt;&lt;&lt;</strong></a><br><br><em>(Right-click and select \"Open in new tab\" if the link does not open in a new tab automatically.)</em><br><br>After completing the task in the interface, close that tab and return here to continue the survey.", "DefaultChoices": false, "DataExportTag": "Q10", "QuestionID": "QID10", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Scenario: App Permission Request", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID11", "SecondaryAttribute": "Scenario: Cookie Consent Banner", "TertiaryAttribute": null, "Payload": {"QuestionText": "<strong>Scenario: Cookie Consent Banner</strong><br><br>A fictional e-commerce website displays a cookie consent banner upon first visit. Review cookie options and select your preferences for tracking and advertising cookies.<br><br>Categories: Essential (required), Analytics, Advertising, Third-party sharing<br><br><em>Please interact with the interface as you normally would.</em><br><br><br><a href=\"https://nehakotwal.github.io/dark-patterns-study/s2_control_cookie_consent.html\" target=\"_blank\"><strong>&gt;&gt;&gt; CLICK HERE TO OPEN THE SHOP SMART INTERFACE &lt;&lt;&lt;</strong></a><br><br><em>(Right-click and select \"Open in new tab\" if the link does not open in a new tab automatically.)</em><br><br>After completing the task in the interface, close that tab and return here to continue the survey.", "DefaultChoices": false, "DataExportTag": "Q11", "QuestionID": "QID11", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Scenario: Cookie Consent Banner", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID12", "SecondaryAttribute": "Scenario: Account Privacy Settings", "TertiaryAttribute": null, "Payload": {"QuestionText": "<strong>Scenario: Account Privacy Settings</strong><br><br>A fictional streaming service prompts you to review privacy settings. Configure your profile visibility, watch history sharing, and personalization settings.<br><br>Settings: Profile visibility, Watch history sharing, Personalized recommendations, Partner data sharing<br><br><em>Please interact with the interface as you normally would.</em><br><br><br><a href=\"https://nehakotwal.github.io/dark-patterns-study/s3_control_privacy_settings.html\" target=\"_blank\"><strong>&gt;&gt;&gt; CLICK HERE TO OPEN THE STREAM VIEW INTERFACE &lt;&lt;&lt;</strong></a><br><br><em>(Right-click and select \"Open in new tab\" if the link does not open in a new tab automatically.)</em><br><br>After completing the task in the interface, close that tab and return here to continue the survey.", "DefaultChoices": false, "DataExportTag": "Q12", "QuestionID": "QID12", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Scenario: Account Privacy Settings", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID13", "SecondaryAttribute": "Scenario: App Permission Request", "TertiaryAttribute": null, "Payload": {"QuestionText": "<strong>Scenario: App Permission Request</strong><br><br>A fictional social media app requests various permissions during installation. Review the permission requests and decide which permissions to grant or deny.<br><br>Permissions: Camera access, Location (always), Contacts, Microphone, Photo library<br><br><em>Please interact with the interface as you normally would.</em><br><br><br><a href=\"https://nehakotwal.github.io/dark-patterns-study/s1_dark_app_permissions.html\" target=\"_blank\"><strong>&gt;&gt;&gt; CLICK HERE TO OPEN THE CONNECT HUB INTERFACE &lt;&lt;&lt;</strong></a><br><br><em>(Right-click and select \"Open in new tab\" if the link does not open in a new tab automatically.)</em><br><br>After completing the task in the interface, close that tab and return here to continue the survey.", "DefaultChoices": false, "DataExportTag": "Q13", "QuestionID": "QID13", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Scenario: App Permission Request", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID14", "SecondaryAttribute": "Scenario: Cookie Consent Banner", "TertiaryAttribute": null, "Payload": {"QuestionText": "<strong>Scenario: Cookie Consent Banner</strong><br><br>A fictional e-commerce website displays a cookie consent banner upon first visit. Review cookie options and select your preferences for tracking and advertising cookies.<br><br>Categories: Essential (required), Analytics, Advertising, Third-party sharing<br><br><em>Please interact with the interface as you normally would.</em><br><br><br><a href=\"https://nehakotwal.github.io/dark-patterns-study/s2_dark_cookie_consent.html\" target=\"_blank\"><strong>&gt;&gt;&gt; CLICK HERE TO OPEN THE SHOP SMART INTERFACE &lt;&lt;&lt;</strong></a><br><br><em>(Right-click and select \"Open in new tab\" if the link does not open in a new tab automatically.)</em><br><br>After completing the task in the interface, close that tab and return here to continue the survey.", "DefaultChoices": false, "DataExportTag": "Q14", "QuestionID": "QID14", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": false}, "Configuration": {"QuestionDescriptionOption": "UseText"}, "QuestionDescription": "Scenario: Cookie Consent Banner", "ChoiceOrder": [], "Validation": {"Settings": {"Type": "None"}}, "GradingData": [], "Language": [], "NextChoiceId": 7, "NextAnswerId": 1}}, {"SurveyID": "SV_6KBINKkF77t2b5k", "Element": "SQ", "PrimaryAttribute": "QID15", "SecondaryAttribute": "Scenario: Account Privacy Settings", "TertiaryAttribute": null, "Payload": {"QuestionText": "<strong>Scenario: Account Privacy Settings</strong><br><br>A fictional streaming service prompts you to review privacy settings. Configure your profile visibility, watch history sharing, and personalization settings.<br><br>Settings: Profile visibility, Watch history sharing, Personalized recommendations, Partner data sharing<br><br><em>Please interact with the interface as you normally would.</em><br><br><br><a href=\"https://nehakotwal.github.io/dark-patterns-study/s3_dark_privacy_settings.html\" target=\"_blank\"><strong>&gt;&gt;&gt; CLICK HERE TO OPEN THE STREAM VIEW INTERFACE &lt;&lt;&lt;</strong></a><br><br><em>(Right-click and select \"Open in new tab\" if the link does not open in a new tab automatically.)</em><br><br>After completing the task in the interface, close that tab and return here to continue the survey.", "DefaultChoices": false, "DataExportTag": "Q15", "QuestionID": "QID15", "QuestionType": "DB", "Selector": "TB", "DataVisibility": {"Private": false, "Hidden": f